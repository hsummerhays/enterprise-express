{
	"name": "enterprise-express",
	"version": "1.0.0",
	"description": "A reference architecture for building maintainable, enterprise-grade Express.js services in Node.js",
	"main": "dist/server.js",
	"scripts": {
		"test": "vitest",
		"dev": "tsx watch --env-file=.env src/server.ts",
		"build": "tsc",
		"start": "node --env-file=.env dist/server.js",
		"lint": "biome check ./src",
		"format": "biome format --write ./src"
	},
	"keywords": [],
	"author": "Hugh Summerhays",
	"license": "MIT",
	"type": "module",
	"dependencies": {
		"@asteasolutions/zod-to-openapi": "^8.4.3",
		"@scalar/express-api-reference": "^0.9.0",
		"argon2": "^0.44.0",
		"cors": "^2.8.6",
		"express": "^5.2.1",
		"express-rate-limit": "^8.3.0",
		"helmet": "^8.1.0",
		"jose": "^6.2.0",
		"pino": "^10.3.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/node": "^25.3.3",
		"@types/supertest": "^7.2.0",
		"pino-pretty": "^13.1.3",
		"supertest": "^7.2.2",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	}
}